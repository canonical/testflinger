# Server charm sub-recipes.
mod charm

[doc('Describe usage and list the available recipes.')]
help:
    @echo '{{ BOLD }}Testflinger Server{{ NORMAL }}'
    @echo
    @echo 'For usage details for a specific recipe, run {{ CYAN }}just --usage RECIPE{{ NORMAL }}'
    @echo
    @just --list --unsorted

[doc('Generate OpenAPI schema.')]
[group('project')]
schema:
    @uvx tox run -e schema

[doc('Check OpenAPI schema.')]
[group('project')]
[group('test')]
check-schema:
    @uvx tox run -e check-schema

[doc('Add a dependency (uv add ...).')]
[group('venv')]
[positional-arguments]
add +args:
    @uv add "$@"

[doc('Remove a dependency (uv remove ...).')]
[group('venv')]
[positional-arguments]
remove +args:
    @uv remove "$@"

[doc('Generate lockfile.')]
[group('venv')]
lock:
    @uv lock

[doc('Check lockfile.')]
[group('venv')]
check-lock:
    @uvx tox run -e lock

[doc("Update the project's environment.")]
[group('venv')]
venv:
    @uv sync
    @echo 'Activate the Python environment: {{ CYAN }}source .venv/bin/activate{{ NORMAL }}'

[doc('Format all files.')]
[group('lint')]
format:
    @uvx tox run -e format

[doc('Lint all files.')]
[group('lint')]
lint:
    @uvx tox run -e lint

[doc('Run unit tests.')]
[group('test')]
test:
    @uvx tox run -e unit

[doc('Run all checks.')]
[group('test')]
check: lint format test check-schema
    @echo 'Server checks done!'

[doc('Run the server.')]
[group('deploy')]
serve:
    @docker compose up --build --detach testflinger

[doc('Tear down and restart the local deployment.')]
[group('deploy')]
restart: teardown serve

[doc('Tear down local deployment.')]
[group('deploy')]
teardown:
    @docker compose down

[doc('Follow the testflinger server logs.')]
[group('deploy')]
logs:
    @docker compose logs --follow testflinger

[doc('Run the client credentials tool.')]
[group('deploy')]
admin:
    @docker compose exec testflinger client_credentials_admin

[doc('Populate the server with sample data.')]
[group('deploy')]
[positional-arguments]
populate *args:
    @docker compose exec testflinger python3 devel/create_dev_admin.py
    @uv run devel/create_sample_data.py "$@"

[doc('Populate the server with a large sample data set.')]
[group('deploy')]
populate-large:
    @just populate \
        --agents 3000 \
        --jobs 500 \
        --queues 4500 \
        --advertised-queues 2

[doc('Add required hostnames to the hosts file to ensure that `dex` and `testflinger-server` and `testflinger-metrics` are available for local testing.')]
[group('deploy')]
set-up-hosts-file:
    #!/usr/bin/env bash
    set -euo pipefail
    # When any hostname is missing, add all hostnames:
    # dex, testflinger-server, testflinger-metrics as hostnames
    LINE="127.0.0.1 dex testflinger-server testflinger-metrics"
    if ! grep -Eq '(^|[[:space:]])dex($|[[:space:]])' /etc/hosts || \
       ! grep -Eq '(^|[[:space:]])testflinger-server($|[[:space:]])' /etc/hosts || \
       ! grep -Eq '(^|[[:space:]])testflinger-metrics($|[[:space:]])' /etc/hosts; then
        echo "$LINE" | tee -a /etc/hosts >/dev/null
    fi
