    "GET": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/agents/provision_logs/<agent_name>": {
    "POST": ["AGENT"]
  },
  "/v1/agents/queues": {
    "POST": ["AGENT", "MANAGER", "ADMIN"],
    "GET": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/client-permissions/<client_id>": {
    "DELETE": ["ADMIN"],
    "GET": ["MANAGER", "ADMIN"],
    "PUT": ["MANAGER", "ADMIN"]
  },
  "/v1/client-permissions": {
    "GET": ["MANAGER", "ADMIN"]
  },
