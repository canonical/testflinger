    "POST": ["AGENT", "MANAGER", "ADMIN"],
    "GET": ["AGENT", "CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/agents/images": {
    "POST": ["AGENT", "MANAGER", "ADMIN"]
  },
