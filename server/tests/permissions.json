    "GET": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/job/<job_id>/action": {
    "POST": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/job/<job_id>/attachments": {
    "GET": ["AGENT"],
    "POST": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/job/<job_id>/events": {
    "POST": ["AGENT"]
  },
  "/v1/job/<job_id>/position": {
    "GET": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/job/search": {
    "GET": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/oauth2/revoke": {
    "POST": ["ADMIN"]
  },
  "/v1/queues/<queue_name>/agents": {
    "GET": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
  "/v1/queues/<queue_name>/jobs": {
    "GET": ["CONTRIBUTOR", "MANAGER", "ADMIN"]
  },
